# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=report_generator
DB_USER=root
DB_PASSWORD=your_password

# 扣子API配置（必填）
COZE_API_KEY=your_coze_api_key_here
COZE_BASE_URL=https://api.coze.cn
COZE_WORKFLOW_ID=your_workflow_id

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# 文件存储
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# CORS配置
CORS_ORIGINS=["*"]
